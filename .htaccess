# Set home.html as default directory index
DirectoryIndex home.html

# Enable rewrite engine
RewriteEngine On

# Force remove .html from URLs in address bar (redirect)
RewriteCond %{THE_REQUEST} ^GET\ /(.*)\\.html\ HTTP
RewriteRule (.*)\\.html$ /$1 [R=301,L]

# Redirect index to home (without .html)
RewriteRule ^index$ home [R=301,L]
RewriteRule ^index\\.html$ home [R=301,L]

# ─── Clean Class URLs: /9  /10  /11  /12 ─────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(9|10|11|12)$ /class.html?class=$1 [L,QSA]

# ─── Clean Subject URLs: /9/biology  /12/pakistan-studies ────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(9|10|11|12)/([a-z0-9][a-z0-9-]*)$ /subject.html?class=$1&subject=$2 [L,QSA]

# ─── Serve other clean URLs by appending .html ───────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
